{
  "schema": "grok16-platform-release/v1",
  "distro_version": "4.7.0",
  "distro_tag": "v4.7.0",
  "g16_version": "16.2.0",
  "pkgversion": "Grok16-16.2.0",
  "upstream_gcc": "releases/gcc-15",
  "release_model": "source_bootstrap_per_platform",
  "statement": "Grok16 ships source + forge; each silicon/OS family bootstraps locally. Linker doctrine witnesses 16+ targets including RISC-V.",
  "doctrine": "data/g16-linker-doctrine.json",
  "launch": {
    "extension": ".launch",
    "schema": "queen-launch/v1",
    "verify": "scripts/grok16-launch-verify.sh",
    "module": "Queen/lib/queen-launch-chamber.py",
    "portable_root": "${GROK16_ROOT}/examples/<name>"
  },
  "platforms": [
    {
      "id": "linux-gnu-x86_64",
      "os": "linux",
      "arch": "x86_64",
      "format": "elf",
      "bootstrap": {"CC": "gcc", "CXX": "g++", "deps": "build-essential flex bison libgmp-dev libmpfr-dev libmpc-dev"},
      "cross_prefix": null,
      "notes": "Primary dev + bench host"
    },
    {
      "id": "linux-gnu-i386",
      "os": "linux",
      "arch": "i386",
      "format": "elf",
      "bootstrap": {"CC": "gcc", "CXX": "g++", "multilib": true},
      "cross_prefix": "i686-linux-gnu-",
      "notes": "32-bit GNU/Linux"
    },
    {
      "id": "linux-gnu-aarch64",
      "os": "linux",
      "arch": "aarch64",
      "format": "elf",
      "bootstrap": {"host": "linux-gnu-x86_64"},
      "cross_prefix": "aarch64-linux-gnu-",
      "notes": "ARM64 Linux — cross bootstrap from x86_64 host"
    },
    {
      "id": "linux-gnu-arm",
      "os": "linux",
      "arch": "arm",
      "format": "elf",
      "bootstrap": {"host": "linux-gnu-x86_64"},
      "cross_prefix": "arm-linux-gnueabihf-",
      "notes": "ARM32 GNU/Linux"
    },
    {
      "id": "linux-gnu-riscv64",
      "os": "linux",
      "arch": "riscv64",
      "format": "elf",
      "bootstrap": {"host": "linux-gnu-x86_64"},
      "cross_prefix": "riscv64-linux-gnu-",
      "notes": "RISC-V 64 — cross GCC + binutils; g16 linker emulation elf64lriscv"
    },
    {
      "id": "android-aarch64",
      "os": "android",
      "arch": "aarch64",
      "format": "elf",
      "bootstrap": {"ndk": true, "ANDROID_NDK_ROOT": "required"},
      "triple": "aarch64-linux-android",
      "notes": "NDK r26+ recommended"
    },
    {
      "id": "android-arm",
      "os": "android",
      "arch": "arm",
      "format": "elf",
      "bootstrap": {"ndk": true},
      "triple": "armv7a-linux-androideabi"
    },
    {
      "id": "android-x86_64",
      "os": "android",
      "arch": "x86_64",
      "format": "elf",
      "bootstrap": {"ndk": true},
      "triple": "x86_64-linux-android"
    },
    {
      "id": "darwin-x86_64",
      "os": "darwin",
      "arch": "x86_64",
      "format": "mach-o",
      "bootstrap": {"CC": "clang", "CXX": "clang++"},
      "notes": "macOS Intel — bootstrap on host"
    },
    {
      "id": "darwin-aarch64",
      "os": "darwin",
      "arch": "aarch64",
      "format": "mach-o",
      "bootstrap": {"CC": "clang", "CXX": "clang++"},
      "notes": "Apple Silicon"
    },
    {
      "id": "ios-aarch64",
      "os": "ios",
      "arch": "aarch64",
      "format": "mach-o",
      "bootstrap": {"xcode": true},
      "triple": "arm64-apple-ios"
    },
    {
      "id": "win32-x86_64",
      "os": "windows",
      "arch": "x86_64",
      "format": "pe",
      "bootstrap": {"mingw": true},
      "triple": "x86_64-pc-windows-msvc"
    },
    {
      "id": "win32-aarch64",
      "os": "windows",
      "arch": "aarch64",
      "format": "pe",
      "bootstrap": {"mingw": true},
      "triple": "aarch64-pc-windows-msvc"
    },
    {
      "id": "bare-elf-x86_64",
      "os": "none",
      "arch": "x86_64",
      "format": "elf",
      "bootstrap": {"host": "linux-gnu-x86_64"},
      "notes": "Bare-metal ELF"
    },
    {
      "id": "bare-elf-aarch64",
      "os": "none",
      "arch": "aarch64",
      "format": "elf",
      "bootstrap": {"host": "linux-gnu-x86_64"},
      "notes": "Bare-metal AArch64"
    },
    {
      "id": "bare-elf-riscv64",
      "os": "none",
      "arch": "riscv64",
      "format": "elf",
      "bootstrap": {"host": "linux-gnu-x86_64"},
      "cross_prefix": "riscv64-linux-gnu-",
      "notes": "Bare-metal RISC-V"
    }
  ],
  "assets": [
    "grok16-{version}-src.tar.gz",
    "grok16-{version}-platforms.json",
    "grok16-{version}-PLATFORMS.md"
  ],
  "gates": [
    "scripts/grok16-test-gate.sh smoke",
    "scripts/grok16-launch-verify.sh",
    "scripts/grok16-toolchain.sh test-battery-release"
  ]
}