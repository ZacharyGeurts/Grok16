    "m6809": ["asm", "basic", "c", "forth", "cobol"],
    "m6502": ["asm", "basic", "forth", "verilog"],
    "z80": ["asm", "basic", "forth", "c", "pascal"],
    "arm": ["c", "cxx", "rust", "go", "swift", "kotlin", "ammolang", "python", "dart"],
