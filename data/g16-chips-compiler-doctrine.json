    "sh4": ["c", "cxx"],
    "cyrix": ["asm", "c", "cxx", "turbo_pascal", "pascal", "delphi"],
    "coco": ["basic", "asm", "forth"]
  },
  "isa_chip_hints": {
    "x86": ["host_cpu", "chips_hot"],
    "m6502": ["chips_6502", "chips_6507", "chips_2a03", "chips_2c02"],
    "z80": ["chips_z80"],
    "m6809": ["chips_6809"],
    "arm": ["chips_arm"],
    "riscv": ["chips_riscv"],
    "combinatronics": ["FieldChips", "chips_hot"],
    "cyrix": ["cyrix_6x86"],
    "coco": ["chips_coco"]
  },
  "driver_lane": {
    "g16-cc": "native_direct",
    "g16-cxx": "native_direct",
    "g16-as": "native_direct",
    "g16-objc": "native_direct",
    "g16-rust": "chips_native",
    "g16-go": "chips_native",
    "g16-zig": "chips_native",
    "g16-gfortran": "chips_native",
    "g16-gdc": "chips_native",
    "g16-gnat": "chips_native",
    "g16-fpc": "chips_native",
    "g16-qbasic": "chips_native",
    "g16-aml": "combinatronics_native",
    "gpy-16": "interp_vm",
    "g16-interp": "chips_lower"
