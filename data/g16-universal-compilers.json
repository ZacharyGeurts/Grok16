{
  "schema": "g16-universal-compilers/v1",
  "title": "Every compiler ever — Grok16 universal dispatch",
  "motto": "One g16 stack · every language · browser tab · secured · transparent · insta-rewrite",
  "module": "lib/g16-universal-compiler.py",
  "security": "lib/g16-code-security.py",
  "browser_tab": {
    "ammocode_root": "../AmmoCode",
    "tab_page": "tab.html",
    "api": "/api/ammocode",
    "default_port": 9555
  },
  "categories": {
    "compiled": ["c", "cxx", "java", "kotlin", "scala", "rust", "go", "zig", "d", "fortran", "ada", "objc", "csharp", "swift", "pascal", "delphi", "cobol", "nim", "haskell", "ocaml", "asm"],
    "scripted": ["python", "javascript", "typescript", "shell", "perl", "ruby", "php", "lua", "r", "julia", "elixir", "erlang", "clojure", "groovy", "tcl", "awk", "vbscript", "vba", "powershell"],
    "web": ["html", "css", "scss", "less", "svg", "wasm", "wat", "graphql", "vue", "svelte"],
    "data": ["json", "jsonc", "yaml", "toml", "xml", "ini", "csv", "tsv", "protobuf", "avro"],
    "config": ["dockerfile", "makefile", "cmake", "nginx", "apache", "systemd", "cron"],
    "legacy": ["basic", "qbasic", "turbo_pascal", "fortran", "algol", "snobol", "forth", "apl", "ammolang", "field"]
  },
  "compilers": {
    "g16": {"langs": ["c", "cxx", "asm", "objc"], "driver": "bin/g16", "compile": true},
    "gpy16": {"langs": ["python"], "driver": "bin/gpy-16", "interpret": true},
    "javac": {"langs": ["java"], "driver": "javac", "compile": true, "fallback": "g16-ai-compile"},
    "rustc": {"langs": ["rust"], "driver": "rustc", "compile": true, "fallback": "g16"},
    "go": {"langs": ["go"], "driver": "go", "compile": true, "fallback": "g16"},
    "zig": {"langs": ["zig"], "driver": "zig", "compile": true, "fallback": "g16"},
    "node": {"langs": ["javascript", "typescript"], "driver": "node", "check": true},
    "php": {"langs": ["php"], "driver": "php", "check": true},
    "ruby": {"langs": ["ruby"], "driver": "ruby", "check": true},
    "perl": {"langs": ["perl"], "driver": "perl", "check": true},
    "lua": {"langs": ["lua"], "driver": "lua", "check": true},
    "kotlin": {"langs": ["kotlin"], "driver": "kotlinc", "compile": true, "fallback": "g16-ai-compile"},
    "csharp": {"langs": ["csharp"], "driver": "mcs", "compile": true, "fallback": "g16-ai-compile"},
    "swift": {"langs": ["swift"], "driver": "swiftc", "compile": true, "fallback": "g16-ai-compile"},
    "shellcheck": {"langs": ["shell"], "driver": "shellcheck", "check": true}
  },
  "discern_fallback": "data/g16-universal-extensions.json"
}