{
  "schema": "grok16-profiles/v2",
  "product": "Grok16",
  "cxx_std_default": "gnu++26",
  "c_std_default": "gnu17",
  "release_profile": {
    "description": "Production Field build — LTO + PGO + field_opt flags",
    "env": {
      "G16_RELEASE_PROFILE": "1",
      "G16_ENABLE_LTO": "1",
      "G16_ENABLE_PGO": "1",
      "G16_FIELD_SPEED": "1"
    },
    "default_bench_profile": "field_opt"
  },
  "field_macros": {
    "FIELD_ENTROPY_DISPATCH": "Queen/Hostess7 wave-dispatch entropy gate",
    "FIELD_X86_DIE": "FieldX86 die layout (KILROY / CANVAS ABI)",
    "FIELD_WAVE_PHASE": "Wave phase decoupling for CANVAS.compute paths",
    "G16_FIELD_SPEED": "Field-Opt speed profile active (unroll/vector/entropy scheduling)",
    "GROK16_PROFILE_AI": "AI build profile active",
    "GROK16_PROFILE_FIELD": "Field compute profile active",
    "GROK16_PROFILE_FIELD_OPT": "Field-Opt throughput profile active",
    "GROK16_PROFILE_VULKAN": "Vulkan/RTX-oriented CPU kernel profile"
  },
  "profiles": {
    "field_opt": {
      "description": "Field-Opt — entropy/oracle, wave phase, FieldX86 emulation throughput",
      "cxx_std": "gnu++26",
      "c_std": "gnu17",
      "c_flags": ["-std=gnu17", "-O3", "-march=native", "-mtune=native", "-ftree-vectorize", "-funroll-loops", "-fomit-frame-pointer"],
      "bench_source": "examples/field-nexus-bench/field_nexus_bench.cpp",
      "cxx_flags": [
        "-std=gnu++26",
        "-O3",
        "-march=native",
        "-mtune=native",
        "-ftree-vectorize",
        "-fvect-cost-model=unlimited",
        "-funroll-loops",
        "-finline-functions",
        "-fomit-frame-pointer",
        "-ffast-math",
        "-fno-trapping-math",
        "-fopenmp-simd"
      ],
      "link_flags": ["-flto=thin"],
      "definitions": [
        "GROK16_PROFILE_FIELD_OPT=1",
        "G16_FIELD_SPEED=1",
        "FIELD_ENTROPY_DISPATCH=1",
        "FIELD_X86_DIE=1",
        "FIELD_WAVE_PHASE=1"
      ]
    },
    "ai_agent": {
      "description": "AI agent compile — fast iterative builds, JSON diagnostics, truth-floor macros",
      "cxx_std": "gnu++26",
      "c_std": "gnu17",
      "bench_source": "examples/ai-matrix-bench/matrix_bench.cpp",
      "cxx_flags": [
        "-std=gnu++26",
        "-O2",
        "-pipe",
        "-march=native",
        "-ffunction-sections",
        "-fdata-sections",
        "-fno-diagnostics-show-caret",
        "-fno-diagnostics-color",
        "-fmax-errors=5",
        "-ftree-vectorize",
        "-funroll-loops",
        "-finline-functions"
      ],
      "c_flags": [
        "-std=gnu17",
        "-O2",
        "-pipe",
        "-march=native",
        "-fno-diagnostics-show-caret",
        "-fmax-errors=5"
      ],
      "link_flags": ["-Wl,--gc-sections"],
      "definitions": [
        "GROK16_PROFILE_AI=1",
        "GROK16_AI_AGENT=1",
        "HOSTESS_TRUTH_FLOOR=58",
        "FIELD_ENTROPY_DISPATCH=1"
      ]
    },
    "ai": {
      "description": "AI / NEXUS behavioral scoring — matrix-friendly, simd/mdspan paths",
      "cxx_std": "gnu++26",
      "bench_source": "examples/ai-matrix-bench/matrix_bench.cpp",
      "cxx_flags": [
        "-std=gnu++26",
        "-O3",
        "-march=native",
        "-mtune=native",
        "-ffast-math",
        "-funroll-loops",
        "-finline-functions",
        "-fomit-frame-pointer",
        "-fno-semantic-interposition",
        "-ftree-vectorize"
      ],
      "link_flags": ["-flto=thin"],
      "definitions": ["GROK16_PROFILE_AI=1", "FIELD_ENTROPY_DISPATCH=1"]
    },
    "field_compute": {
      "description": "Field compute / FieldX86 / CANVAS-style CPU kernels",
      "cxx_std": "gnu++26",
      "bench_source": "examples/field-canvas-kernel/field_dispatch.cpp",
      "cxx_flags": [
        "-std=gnu++26",
        "-O3",
        "-march=native",
        "-fopenmp-simd",
        "-fvect-cost-model=unlimited",
        "-fno-trapping-math"
      ],
      "link_flags": ["-fopenmp"],
      "definitions": ["GROK16_PROFILE_FIELD=1", "FIELD_X86_DIE=1", "FIELD_ENTROPY_DISPATCH=1"]
    },
    "hostess_secure": {
      "description": "Hostess 7 memory-safe mandate — stack/clash/CFI, fortify, no strict-aliasing UB",
      "cxx_std": "gnu++26",
      "c_std": "gnu17",
      "bench_source": "examples/field-nexus-bench/field_nexus_bench.cpp",
      "cxx_flags": [
        "-std=gnu++26",
        "-O2",
        "-fstack-protector-strong",
        "-fstack-clash-protection",
        "-fcf-protection=full",
        "-fno-strict-aliasing",
        "-D_FORTIFY_SOURCE=3",
        "-fPIE",
        "-Wformat",
        "-Wformat-security",
        "-Werror=format-security"
      ],
      "c_flags": [
        "-std=gnu17",
        "-O2",
        "-fstack-protector-strong",
        "-fstack-clash-protection",
        "-fcf-protection=full",
        "-fno-strict-aliasing",
        "-D_FORTIFY_SOURCE=3",
        "-fPIE"
      ],
      "link_flags": ["-Wl,-z,relro", "-Wl,-z,now", "-Wl,-z,noexecstack", "-pie"],
      "definitions": ["GROK16_HOSTESS_SECURE=1", "G16_FIELD_MANDATE=1", "HOSTESS_TRUTH_FLOOR=58"]
    },
    "forever": {
      "description": "Forever profile — max field speed + LTO + all Hostess gates for production",
      "cxx_std": "gnu++26",
      "c_std": "gnu17",
      "bench_source": "examples/field-nexus-bench/field_nexus_bench.cpp",
      "cxx_flags": [
        "-std=gnu++26",
        "-O3",
        "-march=native",
        "-mtune=native",
        "-flto=thin",
        "-fstack-protector-strong",
        "-fstack-clash-protection",
        "-fcf-protection=full",
        "-ftree-vectorize",
        "-fvect-cost-model=unlimited",
        "-funroll-loops",
        "-finline-functions",
        "-fomit-frame-pointer",
        "-fopenmp-simd",
        "-D_FORTIFY_SOURCE=3"
      ],
      "c_flags": ["-std=gnu17", "-O3", "-march=native", "-flto=thin", "-fstack-protector-strong"],
      "link_flags": ["-flto=thin", "-Wl,-z,relro", "-Wl,-z,now", "-pie"],
      "definitions": [
        "GROK16_FOREVER=1",
        "GROK16_PROFILE_FIELD_OPT=1",
        "G16_FIELD_SPEED=1",
        "FIELD_ENTROPY_DISPATCH=1",
        "HOSTESS_TRUTH_FLOOR=58"
      ]
    },
    "memory_safe": {
      "description": "Memory-safe language builds — Rust/Go/Zig secure defaults via field drivers",
      "cxx_std": "gnu++26",
      "bench_source": "examples/ai-matrix-bench/matrix_bench.cpp",
      "cxx_flags": ["-std=gnu++26", "-O2", "-fstack-protector-strong"],
      "link_flags": ["-Wl,-z,relro", "-Wl,-z,now"],
      "definitions": ["GROK16_MEMORY_SAFE=1", "HOSTESS_TRUTH_FLOOR=58"]
    },
    "expert": {
      "description": "Expert validation tier — Hostess gates + field_opt + ironclad/linker witness (0.9e → 1.0)",
      "cxx_std": "gnu++26",
      "c_std": "gnu17",
      "bench_source": "examples/field-nexus-bench/field_nexus_bench.cpp",
      "cxx_flags": [
        "-std=gnu++26",
        "-O3",
        "-march=native",
        "-fstack-protector-strong",
        "-fstack-clash-protection",
        "-fcf-protection=full",
        "-ftree-vectorize",
        "-fvect-cost-model=unlimited",
        "-funroll-loops",
        "-D_FORTIFY_SOURCE=3"
      ],
      "c_flags": ["-std=gnu17", "-O3", "-march=native", "-fstack-protector-strong", "-D_FORTIFY_SOURCE=3"],
      "link_flags": ["-Wl,-z,relro", "-Wl,-z,now", "-pie"],
      "definitions": [
        "GROK16_EXPERT_TIER=1",
        "GROK16_PROFILE_FIELD_OPT=1",
        "GROK16_HOSTESS_SECURE=1",
        "G16_FIELD_MANDATE=1",
        "HOSTESS_TRUTH_FLOOR=58",
        "FIELD_ENTROPY_DISPATCH=1"
      ]
    },
    "heavy": {
      "description": "Heavy validation tier — forever + thin LTO + full field speed (gate before 1.0)",
      "cxx_std": "gnu++26",
      "c_std": "gnu17",
      "bench_source": "examples/field-nexus-bench/field_nexus_bench.cpp",
      "cxx_flags": [
        "-std=gnu++26",
        "-O3",
        "-march=native",
        "-mtune=native",
        "-flto=thin",
        "-fstack-protector-strong",
        "-fstack-clash-protection",
        "-fcf-protection=full",
        "-ftree-vectorize",
        "-fvect-cost-model=unlimited",
        "-funroll-loops",
        "-finline-functions",
        "-fomit-frame-pointer",
        "-fopenmp-simd",
        "-ffast-math",
        "-D_FORTIFY_SOURCE=3"
      ],
      "c_flags": ["-std=gnu17", "-O3", "-march=native", "-flto=thin", "-fstack-protector-strong"],
      "link_flags": ["-flto=thin", "-Wl,-z,relro", "-Wl,-z,now", "-pie"],
      "definitions": [
        "GROK16_HEAVY_TIER=1",
        "GROK16_FOREVER=1",
        "GROK16_PROFILE_FIELD_OPT=1",
        "G16_FIELD_SPEED=1",
        "FIELD_ENTROPY_DISPATCH=1",
        "FIELD_X86_DIE=1",
        "HOSTESS_TRUTH_FLOOR=58"
      ]
    },
    "vulkan_rtx": {
      "description": "AMOURANTHRTX-style RTX prep — SIMD vectorization, shader-adjacent CPU paths",
      "cxx_std": "gnu++26",
      "bench_source": "examples/field-nexus-bench/field_nexus_bench.cpp",
      "cxx_flags": [
        "-std=gnu++26",
        "-O3",
        "-march=native",
        "-msse4.2",
        "-mavx2",
        "-mfma",
        "-ffast-math",
        "-funroll-loops"
      ],
      "link_flags": ["-flto=thin"],
      "definitions": ["GROK16_PROFILE_VULKAN=1", "FIELD_X86_DIE=1"]
    }
  },
  "pgo": {
    "generate_flags": ["-fprofile-generate=${GROK16_ROOT}/data/pgo"],
    "use_flags": ["-fprofile-use=${GROK16_ROOT}/data/pgo", "-fprofile-correction"],
    "data_dir": "${GROK16_ROOT}/data/pgo",
    "workloads": ["field-nexus-bench", "ai-matrix-bench"]
  },
  "speedups": {
    "parallel_jobs": "${GROK16_BUILD_JOBS}",
    "fast_rebuild_default": "G16_FAST_REBUILD=1 unless G16_FULL_REBUILD=1",
    "ccache_doctrine": "safety-only — GROK16_CCACHE_SAFETY=1 for reproducible/Hostess builds; never for speed",
    "field_speed_env": "G16_FIELD_SPEED=1 → field_opt profile + forge scheduling opts",
    "release_env": "G16_RELEASE_PROFILE=1 → LTO + PGO + field_opt",
    "gpy_pair": "GPY-16 GrokVM field-native — g16 discerns python, no host fallback",
    "ai_agent_profile": "fast agent compile tier — -O2 -pipe, no LTO",
    "runtime_target": "500x is field kernel throughput (entropy/vector), not compile memoization"
  }
}