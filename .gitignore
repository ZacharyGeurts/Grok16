# Installed compiler tree (build locally via forge)
/bin/
/lib/
/lib64/
/libexec/
/include/
/share/

# Upstream GCC clone (~1.6G) — fetched by grok16-forge gcc_fetch
/vendor/*
!/vendor/.gitkeep

# Local build tree (keep .gitkeep only)
/build/*
!/build/.gitkeep

# Generated at install
/VERSION
/SELFHOST.json
/cmake/grok16-toolchain.cmake
/data/grok16-toolchain.json
/data/bench/
/data/pgo/
/data/rebuild.log
/.grok16-forge.log
/.grok16-state/

# Example build dirs
/examples/**/build/

# Python
__pycache__/
*.pyc

# Build artifacts
*.o
*.a
*.so
*.la
*.log